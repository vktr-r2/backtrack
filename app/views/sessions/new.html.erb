<div class="login">
	<div class="container">
		<div class="form">

      <h1>Log in</h1>

        <%= form_for(:session, url: login_path) do |f| %> 
          <%= f.email_field :email, :placeholder => "Email" %> 
          <%= f.password_field :password, :placeholder => "Password" %> 
          <%= f.submit "Login", class: "btn-submit" %>
        <% end %>

        <% if notice %>
          <p class="notice"><%= notice %></p>
        <% end %>

        <% if alert %>
          <p class="alert"><%= alert %></p>
        <% end %>
    </div>
	</div>
</div>s